# PostgreSQL (matches docker-compose.yml defaults)
PG_HOST=localhost
PG_PORT=5433
PG_DB=healthcare_risk
PG_USER=pguser
PG_PASS=pgpassword

# pgAdmin (optional)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASS=admin

# Pipeline config overrides (optional — defaults are in config/config.yaml)
# PIPELINE_N_OPTUNA_TRIALS=50
# PIPELINE_RANDOM_STATE=42
